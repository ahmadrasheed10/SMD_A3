<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">



    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cine"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FF0000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAST"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <TextView
            android:text="Select Items"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Snacks and Drinks"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="26dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/bg_movie_card"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/popcorn"
                android:layout_width="80dp"
                android:layout_height="80dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Popcorn"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="500 RS"
                    android:textColor="#CCCCCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnMinusPop"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="−"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />

                    <TextView
                        android:id="@+id/txtQtyPop"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <Button
                        android:id="@+id/btnPlusPop"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="+"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/bg_movie_card"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/drink"
                android:layout_width="80dp"
                android:layout_height="80dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Cold Drink"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="150 RS"
                    android:textColor="#CCCCCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnMinusDrink"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="−"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />

                    <TextView
                        android:id="@+id/txtQtyDrink"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <Button
                        android:id="@+id/btnPlusDrink"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="+"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/bg_movie_card"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/candy"
                android:layout_width="80dp"
                android:layout_height="80dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Candy"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="100 RS"
                    android:textColor="#CCCCCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnMinusCandy"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="−"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />

                    <TextView
                        android:id="@+id/txtQtyCandy"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <Button
                        android:id="@+id/btnPlusCandy"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="+"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/bg_movie_card"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/nachos"
                android:layout_width="80dp"
                android:layout_height="80dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Nachos"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="250 RS"
                    android:textColor="#CCCCCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnMinusNachos"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="+"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />

                    <TextView
                        android:id="@+id/txtQtyNachos"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <Button
                        android:id="@+id/btnPlusNachos"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="+"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.AppCompat.Button" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>


        <Button
            android:id="@+id/btnConfirm"
            android:text="Confirm"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E50914"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

    </LinearLayout>
</ScrollView>
